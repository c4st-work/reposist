#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int mem[100][100];

int max(int a, int b){
    return (a>b) ? a:b;
}

int maxlcs(char x[], char y[], int i, int j){
    if(i==0||j==0){
        mem[i][j]=0;
        return 0;
    }
    if(mem[i][j]!=-1){
        return mem[i][j];
    }
    if(x[i]==y[j]){
        mem[i][j]=maxlcs(x, y, i-1, j-1)+1;
        return mem[i][j];
    }
    mem[i][j]=max(maxlcs(x, y,i-1, j), maxlcs(x, y, i, j-1));
    return mem[i][j];
}

int main(){
    char x[] = "AGGTAZBfdsf";
    char y[] = "GXTXAZYBasd";
    int m = strlen(x);
    int n = strlen(y);

    int i=m-1;
    int j=n-1;

    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            mem[i][j] = -1;
        }
    }
    printf("%d", maxlcs(x, y, i, j));
}
